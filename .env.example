# GEMINI_API_KEY: Required for Gemini AI Advisor & drafting.
# Configure this with your personal Gemini API Key.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# GOOGLE_CLIENT_ID: Your Google OAuth Client ID.
# Required to enable the Gmail sync callback.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Your Google OAuth Client Secret.
# Required to exchange authorization codes for access/refresh tokens.
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# LOTOS_PASSWORD: The passcode to secure your dashboard.
# Leave blank to disable the login wall (runs in unsecure Local-Only Mode).
LOTOS_PASSWORD="your_secure_passcode_here"

# SESSION_SECRET: Key used to sign local session cookies.
# If left blank, a random secret is generated at server startup (sessions expire on restart).
SESSION_SECRET="your_session_secret_key_here"

# APP_URL: Optional base URL of this hosted instance.
APP_URL="http://localhost:3000"
